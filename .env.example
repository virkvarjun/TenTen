# Meridian environment variables.
# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.
# Every integration degrades gracefully if its key is missing (see Phase 3).

# --- Database (Prisma + Postgres) ---
# Local docker-compose default. Swap for a Neon/Supabase URL in production.
DATABASE_URL="postgresql://meridian:meridian@localhost:5432/meridian?schema=public"

# --- Anthropic (decision engine) ---
# If absent, the app falls back to the deterministic heuristic engine.
ANTHROPIC_API_KEY=""

# --- Auth.js v5 (Google provider: sign-in + Calendar OAuth) ---
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Cron (Phase 3 nightly learning loop) ---
# Shared secret used to authenticate Vercel Cron requests to the learning route.
CRON_SECRET=""
